         RowBox[{"c", "[", 
          RowBox[{"[", "5", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "2"}], ")"}]}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "*", 
           RowBox[{"x", "/", "Pi"}]}], ")"}], "^", 
         RowBox[{"c", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "+", "1"}], ")"}], "^", 
      RowBox[{"(", 
