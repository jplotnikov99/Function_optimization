            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "4"}], ")"}]}]}], "+", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "4", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "3"}], ")"}]}]}], "+", 
