Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"besselK1", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"1", "/", "x"}]}], ")"}], "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "5"}], ")"}]}]}], "+", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
