Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"besselK1", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"1", "/", "x"}]}], ")"}], "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "5"}], ")"}]}]}], "+", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "4"}], ")"}]}]}], "+", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "4", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "3"}], ")"}]}]}], "+", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "5", "]"}], "]"}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/", "2"}], ")"}]}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "*", 
           RowBox[{"x", "/", "Pi"}]}], ")"}], "^", 
         RowBox[{"c", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "+", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", 
          RowBox[{"c", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], ")"}]}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
